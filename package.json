{
  "name": "@more-vaults/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for MoreVaults protocol — viem/wagmi and ethers.js",
  "type": "module",
  "exports": {
    "./viem": {
      "types": "./dist/viem/index.d.ts",
      "import": "./dist/viem/index.js",
      "require": "./dist/viem/index.cjs"
    },
    "./ethers": {
      "types": "./dist/ethers/index.d.ts",
      "import": "./dist/ethers/index.js",
      "require": "./dist/ethers/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "bash tests/run.sh",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "viem": "^2.21.0",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "viem": ">=2.0.0",
    "ethers": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "viem": { "optional": true },
    "ethers": { "optional": true }
  }
}
